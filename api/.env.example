PORT=4000
NODE_ENV=development

# MySQL — point at imported legacy DB or a dev clone
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=u334425891_sbm
# Remote DB (e.g. Hostinger from Render): try DB_SSL=true if connections fail or time out.
# DB_SSL=true
# Optional: enforce certificate verification (stricter)
# DB_SSL_STRICT=true

# Admin JWT (generate a long random string in production)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Public URL of the React app (CORS). Production: https://yourdomain.com (no trailing slash)
WEB_ORIGIN=http://localhost:5173

# --- Render.com ---
# Do NOT set PORT in the Render dashboard; Render injects PORT automatically.
# NODE_ENV=production
# WEB_ORIGIN=https://sbmtourindia.com/
# Hostinger MySQL: hPanel → Databases → Remote MySQL → allow access (Any host % or Render IPs),
# then use the hostname shown there as DB_HOST.

# Canonical site URL for sitemap.xml (no trailing slash). Optional in dev.
# PUBLIC_SITE_URL=https://www.sbmtourindia.com
